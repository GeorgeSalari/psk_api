<h2>Запрос на звонок</h2>

<table style="border-collapse: collapse; width: 100%; max-width: 500px;">
  <tr>
    <td style="padding: 8px 12px; font-weight: bold; border-bottom: 1px solid #eee;">Имя:</td>
    <td style="padding: 8px 12px; border-bottom: 1px solid #eee;"><%= @call_request.contact_name %></td>
  </tr>
  <tr>
    <td style="padding: 8px 12px; font-weight: bold; border-bottom: 1px solid #eee;">Телефон:</td>
    <td style="padding: 8px 12px; border-bottom: 1px solid #eee;"><%= @call_request.phone %></td>
  </tr>
  <% if @call_request.comment.present? %>
  <tr>
    <td style="padding: 8px 12px; font-weight: bold; border-bottom: 1px solid #eee;">Комментарий:</td>
    <td style="padding: 8px 12px; border-bottom: 1px solid #eee;"><%= @call_request.comment %></td>
  </tr>
  <% end %>
</table>

<p style="margin-top: 16px; color: #888; font-size: 13px;">
  Запрос получен: <%= @call_request.created_at.strftime("%d.%m.%Y %H:%M") %>
</p>
